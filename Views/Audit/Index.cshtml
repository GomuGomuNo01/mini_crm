@model PagedResult<MiniCrm.Models.AuditLog>
@{
    ViewData["Title"] = "Journal d'audit";

    string ActionBadge(string a) => a switch
    {
        "Création" => "bg-success",
        "Modification" => "bg-info",
        "Suppression" => "bg-danger",
        _ => "bg-secondary"
    };
    string ActionIcon(string a) => a switch
    {
        "Création" => "bi-plus-circle",
        "Modification" => "bi-pencil",
        "Suppression" => "bi-trash",
        _ => "bi-dot"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">
        <i class="bi bi-shield-lock"></i>
        Traçabilité des actions (qui, quoi, quand) — @Model.TotalCount entrée@(Model.TotalCount > 1 ? "s" : "")
    </p>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>Date &amp; heure</th>
                <th>Utilisateur</th>
                <th>Action</th>
                <th>Type</th>
                <th>Élément concerné</th>
                <th>Détails (avant → après)</th>
            </tr>
            </thead>
            <tbody>
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state"><i class="bi bi-inbox"></i>Aucune action enregistrée pour le moment.</div>
                    </td>
                </tr>
            }
            @foreach (var log in Model.Items)
            {
                <tr>
                    <td class="text-muted" style="white-space:nowrap;">
                        @log.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                    </td>
                    <td class="fw-semibold">@log.UserName</td>
                    <td>
                        <span class="badge @ActionBadge(log.Action)"><i class="bi @ActionIcon(log.Action)"></i> @log.Action</span>
                    </td>
                    <td>@log.EntityType</td>
                    <td>
                        @(string.IsNullOrEmpty(log.EntityLabel) ? "—" : log.EntityLabel)
                        @if (log.EntityId.HasValue)
                        {
                            <span class="text-muted small">#@log.EntityId</span>
                        }
                    </td>
                    <td style="max-width: 360px;">
                        @if (string.IsNullOrEmpty(log.Details))
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            <span class="small">@log.Details</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)">Précédent</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)">Suivant</a>
            </li>
        </ul>
    </nav>
}
