@model List<MiniCrm.ViewModels.UserListItem>
@{
    ViewData["Title"] = "Utilisateurs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Gestion des comptes</p>
    <button type="button" class="btn btn-primary" data-modal-url="@Url.Action("Create")" data-title="Nouvel utilisateur">
        <i class="bi bi-person-plus"></i> Nouvel utilisateur
    </button>
</div>

@* Conteneur rechargeable après une action CRUD *@
<div data-live-filter data-target="#userTableContainer" data-url="@Url.Action("Index")" style="display:none"></div>

<div id="userTableContainer">
    <partial name="_UserTable" model="Model" />
</div>
