@model Client
@{
    var initials = string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name.Trim()[..1].ToUpper();

    string StatusBadge(ClientStatus s) => s switch
    {
        ClientStatus.Active => "bg-success",
        ClientStatus.Inactive => "bg-secondary",
        ClientStatus.Prospect => "bg-info text-dark",
        _ => "bg-light text-dark"
    };
    string ContractBadge(ContractStatus s) => s switch
    {
        ContractStatus.Active => "bg-success",
        ContractStatus.Expired => "bg-secondary",
        ContractStatus.Cancelled => "bg-danger",
        ContractStatus.Draft => "bg-warning text-dark",
        _ => "bg-light text-dark"
    };
}

<div class="detail-header">
    <div class="detail-avatar">@initials</div>
    <div class="min-w-0">
        <h4 class="text-truncate">@Model.Name</h4>
        <span class="badge @StatusBadge(Model.Status)">@Model.Status</span>
    </div>
</div>

<div class="detail-list">
    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-envelope"></i> Email</span>
        <span class="detail-value"><a href="mailto:@Model.Email">@Model.Email</a></span>
    </div>
    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-briefcase"></i> Secteur</span>
        <span class="detail-value">@(string.IsNullOrEmpty(Model.Sector) ? "Non renseigné" : Model.Sector)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-calendar3"></i> Créé le</span>
        <span class="detail-value">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label"><i class="bi bi-file-earmark-text"></i> Contrats</span>
        <span class="detail-value">@Model.Contracts.Count</span>
    </div>
</div>

<p class="detail-section-title">Contrats associés</p>
@if (!Model.Contracts.Any())
{
    <p class="detail-empty">Aucun contrat associé.</p>
}
else
{
    foreach (var ct in Model.Contracts)
    {
        <div class="detail-contract">
            <div class="min-w-0">
                <div class="dc-title text-truncate">@ct.Title</div>
                <div class="dc-sub">@ct.StartDate.ToString("dd/MM/yyyy") → @ct.EndDate.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="text-end" style="white-space:nowrap;">
                <div class="fw-semibold">@ct.Amount.ToString("N2") €</div>
                <span class="badge @ContractBadge(ct.Status)">@ct.Status</span>
            </div>
        </div>
    }
}
