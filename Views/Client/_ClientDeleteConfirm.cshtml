@model Client

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" data-ajax-form>
    <input type="hidden" asp-for="Id" />
    <div class="text-center p-2">
        <div class="mx-auto mb-3 d-grid" style="width:56px;height:56px;border-radius:50%;background:#fee2e2;color:#b91c1c;place-items:center;font-size:1.6rem;">
            <i class="bi bi-trash"></i>
        </div>
        <h5 class="fw-bold mb-1">Supprimer le client</h5>
        <p class="text-muted mb-1">Voulez-vous vraiment supprimer <strong>@Model.Name</strong> ?</p>
        <p class="text-danger small mb-4">Ses @Model.Contracts.Count contrat(s) associé(s) seront aussi supprimés. Action irréversible.</p>
        <div class="d-flex gap-2 justify-content-center">
            <button type="button" class="btn btn-outline-secondary px-4" data-crud-close>Annuler</button>
            <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash"></i> Supprimer</button>
        </div>
    </div>
</form>
