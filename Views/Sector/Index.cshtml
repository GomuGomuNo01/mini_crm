@model PagedResult<MiniCrm.Models.Sector>
@{
    ViewData["Title"] = "Secteurs";
    var search = ViewBag.Search as string;
}

<div class="mx-auto" style="max-width: 720px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <p class="text-muted mb-0">Catalogue des secteurs d'activité</p>
        <button type="button" class="btn btn-primary" data-modal-url="@Url.Action("Create")" data-title="Nouveau secteur">
            <i class="bi bi-plus-lg"></i> Nouveau secteur
        </button>
    </div>

    <form class="mb-3" data-live-filter data-target="#sectorTableContainer" data-url="@Url.Action("Index")" onsubmit="return false;">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="search" value="@search" class="form-control" data-filter autocomplete="off"
                   placeholder="Rechercher un secteur..." />
        </div>
    </form>

    <div id="sectorTableContainer">
        <partial name="_SectorTable" model="Model" />
    </div>
</div>
