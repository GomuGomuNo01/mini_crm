@model Sector
@{
    var clientCount = ViewBag.ClientCount as int? ?? 0;
}

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" data-ajax-form>
    <input type="hidden" asp-for="Id" />
    <div class="text-center p-2">
        <div class="mx-auto mb-3 d-grid" style="width:56px;height:56px;border-radius:50%;background:#fee2e2;color:#b91c1c;place-items:center;font-size:1.6rem;">
            <i class="bi bi-trash"></i>
        </div>
        <h5 class="fw-bold mb-1">Supprimer le secteur</h5>
        <p class="text-muted mb-1">Supprimer le secteur <strong>@Model.Name</strong> du catalogue ?</p>
        @if (clientCount > 0)
        {
            <p class="text-danger small mb-4">@clientCount client(s) utilisent ce secteur. Leur valeur sera conservée mais le secteur ne sera plus proposé.</p>
        }
        else
        {
            <p class="text-muted small mb-4">Aucun client n'utilise ce secteur.</p>
        }
        <div class="d-flex gap-2 justify-content-center">
            <button type="button" class="btn btn-outline-secondary px-4" data-crud-close>Annuler</button>
            <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash"></i> Supprimer</button>
        </div>
    </div>
</form>
